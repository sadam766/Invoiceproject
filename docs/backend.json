
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the sales dashboard.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the product."
        },
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "price": {
          "type": "number",
          "description": "Price of the product."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "price"
      ]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer with multiple addresses.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Legal name of the customer (Pusat)."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string", "description": "e.g. Kantor Pusat, Gudang A" },
              "address": { "type": "string" },
              "npwp": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          }
        },
        "ownerId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "ownerId"
      ]
    },
    "Sale": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sale",
      "type": "object",
      "description": "Represents a sale transaction in the sales dashboard.",
      "properties": {
        "soNumber": {
          "type": "string",
          "description": "Unique identifier for the sale transaction (Sales Order number)."
        },
        "customer": {
          "type": "string",
          "description": "Name of the customer."
        },
        "sales": {
          "type": "string",
          "description": "Name of the salesperson."
        },
        "poNumber": {
          "type": "string",
          "description": "Purchase Order number from the customer."
        },
        "amount": {
          "type": "number",
          "description": "Total amount of the sale transaction."
        },
        "status": {
          "type": "string",
          "description": "Status of the sale transaction.",
          "enum": [
            "Paid",
            "Unpaid"
          ]
        },
        "paidDate": {
          "type": "string",
          "description": "Date the sale was paid.",
          "format": "date"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "soNumber",
        "customer",
        "sales",
        "poNumber",
        "amount",
        "status",
        "ownerId"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Represents an invoice document.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "soNumber": {
          "type": "string"
        },
        "poNumber": {
          "type": "string"
        },
        "customer": {
          "type": "string"
        },
        "billingAddress": {
          "type": "string"
        },
        "billingNpwp": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "amount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": [
            "paid",
            "unpaid",
            "sent",
            "draft"
          ]
        },
        "spdNumber": {
          "type": "string",
          "description": "Linked SPD number if any."
        },
        "ownerId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "soNumber",
        "customer",
        "date",
        "amount",
        "status",
        "ownerId"
      ]
    },
    "SPD": {
      "title": "SPD",
      "description": "Surat Pengantar Dokumen (Document Delivery Letter).",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The SPD Number (e.g. SPD/2024/05/001)"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "courier": {
          "type": "string",
          "description": "Name of the courier or expedition."
        },
        "invoices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "invoiceId": { "type": "string" },
              "customer": { "type": "string" },
              "address": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "received", "rejected"] }
            }
          }
        },
        "status": {
          "type": "string",
          "enum": ["in_delivery", "received", "rejected"]
        },
        "ownerId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "date",
        "courier",
        "ownerId"
      ]
    },
    "TaxInvoice": {
      "title": "Tax Invoice",
      "description": "Represents a tax invoice document.",
      "type": "object",
      "properties": {
        "taxInvoiceNumber": {
          "type": "string"
        },
        "buyerNpwp": {
          "type": "string"
        },
        "buyerName": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "taxInvoiceDate": {
          "type": "string",
          "format": "date"
        },
        "invoiceNumber": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        }
      },
      "required": [
        "taxInvoiceNumber",
        "buyerNpwp",
        "buyerName",
        "status",
        "taxInvoiceDate",
        "invoiceNumber",
        "ownerId"
      ]
    },
    "SalesOrder": {
        "title": "Sales Order Item",
        "description": "Represents a single line item within a sales order.",
        "type": "object",
        "properties": {
            "id": {
                "type": "string"
            },
            "soNumber": {
                "type": "string"
            },
            "customer": {
                "type": "string"
            },
            "productName": {
                "type": "string"
            },
            "category": {
                "type": "string"
            },
            "quantity": {
                "type": "number"
            },
            "unit": {
                "type": "string"
            },
            "price": {
                "type": "number"
            },
            "ownerId": {
                "type": "string"
            }
        },
        "required": [
            "id",
            "soNumber",
            "customer",
            "productName",
            "quantity",
            "unit",
            "price",
            "ownerId"
        ]
    },
    "VirtualAccount": {
      "title": "Virtual Account",
      "description": "Represents a customer's Virtual Account for payments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerCode": { "type": "string" },
        "customerName": { "type": "string" },
        "bankName": { "type": "string" },
        "vaNumber": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["customerName", "bankName", "vaNumber", "ownerId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores product information."
    },
    "/customers/{customerId}": {
      "schema": {
        "$ref": "#/entities/Customer"
      },
      "description": "Stores customer data."
    },
    "/sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/Sale"
      },
      "description": "Stores sale transaction data."
    },
    "/invoices/{invoiceId}": {
      "schema": {
        "$ref": "#/entities/Invoice"
      },
      "description": "Stores invoice documents."
    },
    "/users/{uid}": {
      "description": "Stores user profile information, including their role."
    },
    "/salesOrders/{orderId}": {
      "schema": {
          "$ref": "#/entities/SalesOrder"
      },
      "description": "Stores individual items of a sales order."
    },
    "/invoiceNumbers/{invoiceNumberId}": {
      "description": "Stores generated invoice numbers."
    },
    "/spds/{spdId}": {
      "schema": {
        "$ref": "#/entities/SPD"
      },
      "description": "Stores SPD documents."
    },
    "/taxInvoices/{taxInvoiceId}": {
      "schema": {
        "$ref": "#/entities/TaxInvoice"
      },
      "description": "Stores tax invoice documents."
    },
    "/virtualAccounts/{vaId}": {
      "schema": {
        "$ref": "#/entities/VirtualAccount"
      },
      "description": "Stores customer Virtual Account information."
    }
  }
}
