
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the sales dashboard.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the product."
        },
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "price": {
          "type": "number",
          "description": "Price of the product."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "price"
      ]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer in the sales dashboard.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the customer."
        },
        "name": {
          "type": "string",
          "description": "Name of the customer."
        },
        "email": {
          "type": "string",
          "description": "Email address of the customer.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "name",
        "email"
      ]
    },
    "Sale": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sale",
      "type": "object",
      "description": "Represents a sale transaction in the sales dashboard.",
      "properties": {
        "soNumber": {
          "type": "string",
          "description": "Unique identifier for the sale transaction (Sales Order number)."
        },
        "customer": {
          "type": "string",
          "description": "Name of the customer."
        },
        "sales": {
          "type": "string",
          "description": "Name of the salesperson."
        },
        "poNumber": {
          "type": "string",
          "description": "Purchase Order number from the customer."
        },
        "amount": {
          "type": "number",
          "description": "Total amount of the sale transaction."
        },
        "status": {
          "type": "string",
          "description": "Status of the sale transaction.",
          "enum": [
            "Paid",
            "Unpaid"
          ]
        },
        "paidDate": {
          "type": "string",
          "description": "Date the sale was paid.",
          "format": "date"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "soNumber",
        "customer",
        "sales",
        "poNumber",
        "amount",
        "status",
        "ownerId"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Represents an invoice document.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the invoice, often formatted (e.g., INV/2024/001)."
        },
        "soNumber": {
          "type": "string",
          "description": "Sales Order number related to this invoice."
        },
        "poNumber": {
          "type": "string",
          "description": "Purchase Order number from the customer."
        },
        "customer": {
          "type": "string",
          "description": "Name of the customer being invoiced."
        },
        "date": {
          "type": "string",
          "description": "The date the invoice was issued.",
          "format": "date"
        },
        "amount": {
          "type": "number",
          "description": "The total amount of the invoice."
        },
        "status": {
          "type": "string",
          "description": "The current status of the invoice.",
          "enum": [
            "paid",
            "unpaid",
            "sent",
            "draft"
          ]
        },
        "spdNumber": {
          "type": "string",
          "description": "The SPD (Surat Pengantar Dokumen) number associated with this invoice, if any."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "id",
        "soNumber",
        "customer",
        "date",
        "amount",
        "status",
        "ownerId"
      ]
    },
    "SPD": {
      "title": "SPD",
      "description": "Surat Pengantar Dokumen (Document Delivery Letter).",
      "type": "object",
      "properties": {
        "spd": {
          "type": "string",
          "description": "Unique identifier for the SPD."
        },
        "tanggal": {
          "type": "string",
          "format": "date"
        },
        "sales": {
          "type": "string"
        },
        "customer": {
          "type": "string"
        },
        "noInvoice": {
          "type": "string"
        },
        "tanggalInvoice": {
          "type": "string",
          "format": "date"
        },
        "tglTerimaCustomer": {
          "type": "string"
        },
        "tglJatuhTempo": {
          "type": "string"
        },
        "totalPiutang": {
          "type": "number"
        },
        "keterangan": {
          "type": "string"
        },
        "noKuitansi": {
          "type": "string"
        },
        "noFakturPajak": {
          "type": "string"
        },
        "suratJalan": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "spd",
        "tanggal",
        "customer",
        "noInvoice",
        "totalPiutang",
        "ownerId"
      ]
    },
    "TaxInvoice": {
      "title": "Tax Invoice",
      "description": "Represents a tax invoice document.",
      "type": "object",
      "properties": {
        "taxInvoiceNumber": {
          "type": "string",
          "description": "Unique identifier for the tax invoice."
        },
        "buyerNpwp": {
          "type": "string"
        },
        "buyerName": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "taxInvoiceDate": {
          "type": "string",
          "format": "date"
        },
        "invoiceNumber": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "taxInvoiceNumber",
        "buyerNpwp",
        "buyerName",
        "status",
        "taxInvoiceDate",
        "invoiceNumber",
        "ownerId"
      ]
    },
    "SalesOrder": {
        "title": "Sales Order Item",
        "description": "Represents a single line item within a sales order.",
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "description": "Unique identifier for the sales order item."
            },
            "soNumber": {
                "type": "string",
                "description": "The sales order number this item belongs to."
            },
            "customer": {
                "type": "string",
                "description": "The customer associated with this sales order."
            },
            "productName": {
                "type": "string",
                "description": "Name of the product."
            },
            "category": {
                "type": "string",
                "description": "Category of the product."
            },
            "quantity": {
                "type": "number",
                "description": "Quantity of the product ordered."
            },
            "unit": {
                "type": "string",
                "description": "Unit of measurement for the quantity."
            },
            "price": {
                "type": "number",
                "description": "Price per unit of the product."
            },
            "ownerId": {
                "type": "string",
                "description": "The UID of the user who owns this document."
            }
        },
        "required": [
            "id",
            "soNumber",
            "customer",
            "productName",
            "quantity",
            "unit",
            "price",
            "ownerId"
        ]
    },
    "VirtualAccount": {
      "title": "Virtual Account",
      "description": "Represents a customer's Virtual Account for payments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerCode": { "type": "string" },
        "customerName": { "type": "string" },
        "bankName": { "type": "string" },
        "vaNumber": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["customerName", "bankName", "vaNumber", "ownerId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores product information."
    },
    "/customers/{customerId}": {
      "schema": {
        "$ref": "#/entities/Customer"
      },
      "description": "Stores customer data."
    },
    "/sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/Sale"
      },
      "description": "Stores sale transaction data."
    },
    "/invoices/{invoiceId}": {
      "schema": {
        "$ref": "#/entities/Invoice"
      },
      "description": "Stores invoice documents."
    },
    "/users/{uid}": {
      "description": "Stores user profile information, including their role."
    },
    "/salesOrders/{orderId}": {
      "schema": {
          "$ref": "#/entities/SalesOrder"
      },
      "description": "Stores individual items of a sales order."
    },
    "/invoiceNumbers/{invoiceNumberId}": {
      "description": "Stores generated invoice numbers."
    },
    "/spds/{spdId}": {
      "schema": {
        "$ref": "#/entities/SPD"
      },
      "description": "Stores SPD documents."
    },
    "/taxInvoices/{taxInvoiceId}": {
      "schema": {
        "$ref": "#/entities/TaxInvoice"
      },
      "description": "Stores tax invoice documents."
    },
    "/virtualAccounts/{vaId}": {
      "schema": {
        "$ref": "#/entities/VirtualAccount"
      },
      "description": "Stores customer Virtual Account information."
    }
  }
}
