
{
  "entities": {
    "User": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "customerCode": { "type": "string", "description": "Unique ERP identity (e.g. ADH004)" },
        "email": { "type": "string" },
        "addresses": { "type": "array" },
        "billingSchedule": { "type": "string", "description": "Specific days/times for accepting invoices" },
        "virtualAccountNumber": { "type": "string", "description": "16-digit Mandiri VA" },
        "createdBy": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "erpInvoiceId": { "type": "string" },
        "soNumber": { "type": "string" },
        "poNumber": { "type": "string" },
        "customer": { "type": "string" },
        "customerCode": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "vaNumber": { "type": "string" },
        "revisionLogs": { "type": "array" }
      }
    },
    "InvoiceNumber": {
      "title": "Invoice Identity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customer": { "type": "string" },
        "customerCode": { "type": "string" },
        "salesOrder": { "type": "string" },
        "poNumber": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "SalesOrder": {
      "title": "Sales Order Item",
      "type": "object",
      "properties": {
        "soNumber": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "customer": { "type": "string" }
      }
    },
    "SalesListItem": {
      "title": "Purchase Order Registry",
      "type": "object",
      "properties": {
        "poNumber": { "type": "string" },
        "customer": { "type": "string" },
        "amount": { "type": "number" },
        "paidOffline": { "type": "number" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles and roles"
    },
    "/customers/{id}": {
      "schema": "#/entities/Customer",
      "description": "Customer address book"
    },
    "/invoices/{id}": {
      "schema": "#/entities/Invoice",
      "description": "Billing documents with item progress"
    },
    "/invoiceNumbers/{id}": {
      "schema": "#/entities/InvoiceNumber",
      "description": "Identity registry for SAR/ERP numbers"
    },
    "/salesOrders/{id}": {
      "schema": "#/entities/SalesOrder",
      "description": "Sales Order contract items"
    },
    "/sales/{id}": {
      "schema": "#/entities/SalesListItem",
      "description": "Global PO registry"
    },
    "/products/{id}": { "schema": "object", "description": "Master product inventory" },
    "/spds/{id}": { "schema": "object", "description": "Document dispatch tracking" },
    "/taxInvoices/{id}": { "schema": "object", "description": "Tax invoice synchronization" },
    "/virtualAccounts/{id}": { "schema": "object", "description": "Customer payment accounts" }
  }
}
