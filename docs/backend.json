
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the sales dashboard.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the product."
        },
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "price": {
          "type": "number",
          "description": "Price of the product."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "price"
      ]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer in the sales dashboard.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the customer."
        },
        "name": {
          "type": "string",
          "description": "Name of the customer."
        },
        "email": {
          "type": "string",
          "description": "Email address of the customer.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "name",
        "email"
      ]
    },
    "Sale": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sale",
      "type": "object",
      "description": "Represents a sale transaction in the sales dashboard.",
      "properties": {
        "soNumber": {
          "type": "string",
          "description": "Unique identifier for the sale transaction (Sales Order number)."
        },
        "customer": {
          "type": "string",
          "description": "Name of the customer."
        },
        "sales": {
          "type": "string",
          "description": "Name of the salesperson."
        },
        "poNumber": {
          "type": "string",
          "description": "Purchase Order number from the customer."
        },
        "amount": {
          "type": "number",
          "description": "Total amount of the sale transaction."
        },
        "status": {
          "type": "string",
          "description": "Status of the sale transaction.",
          "enum": [
            "Paid",
            "Unpaid"
          ]
        },
        "paidDate": {
          "type": "string",
          "description": "Date the sale was paid.",
          "format": "date"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "soNumber",
        "customer",
        "sales",
        "poNumber",
        "amount",
        "status",
        "ownerId"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Represents an invoice document.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the invoice, often formatted (e.g., INV/2024/001)."
        },
        "soNumber": {
          "type": "string",
          "description": "Sales Order number related to this invoice."
        },
        "poNumber": {
          "type": "string",
          "description": "Purchase Order number from the customer."
        },
        "customer": {
          "type": "string",
          "description": "Name of the customer being invoiced."
        },
        "date": {
          "type": "string",
          "description": "The date the invoice was issued.",
          "format": "date"
        },
        "amount": {
          "type": "number",
          "description": "The total amount of the invoice."
        },
        "status": {
          "type": "string",
          "description": "The current status of the invoice.",
          "enum": [
            "paid",
            "unpaid",
            "sent",
            "draft"
          ]
        },
        "spdNumber": {
          "type": "string",
          "description": "The SPD (Surat Pengantar Dokumen) number associated with this invoice, if any."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "id",
        "soNumber",
        "customer",
        "date",
        "amount",
        "status",
        "ownerId"
      ]
    },
    "SPD": {
      "title": "SPD",
      "description": "Surat Pengantar Dokumen (Document Delivery Letter).",
      "type": "object",
      "properties": {
        "spd": {
          "type": "string",
          "description": "Unique identifier for the SPD."
        },
        "tanggal": {
          "type": "string",
          "format": "date"
        },
        "sales": {
          "type": "string"
        },
        "customer": {
          "type": "string"
        },
        "noInvoice": {
          "type": "string"
        },
        "tanggalInvoice": {
          "type": "string",
          "format": "date"
        },
        "tglTerimaCustomer": {
          "type": "string"
        },
        "tglJatuhTempo": {
          "type": "string"
        },
        "totalPiutang": {
          "type": "number"
        },
        "keterangan": {
          "type": "string"
        },
        "noKuitansi": {
          "type": "string"
        },
        "noFakturPajak": {
          "type": "string"
        },
        "suratJalan": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "spd",
        "tanggal",
        "customer",
        "noInvoice",
        "totalPiutang",
        "ownerId"
      ]
    },
    "TaxInvoice": {
      "title": "Tax Invoice",
      "description": "Represents a tax invoice document.",
      "type": "object",
      "properties": {
        "taxInvoiceNumber": {
          "type": "string",
          "description": "Unique identifier for the tax invoice."
        },
        "buyerNpwp": {
          "type": "string"
        },
        "buyerName": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "taxInvoiceDate": {
          "type": "string",
          "format": "date"
        },
        "invoiceNumber": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this document."
        }
      },
      "required": [
        "taxInvoiceNumber",
        "buyerNpwp",
        "buyerName",
        "status",
        "taxInvoiceDate",
        "invoiceNumber",
        "ownerId"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores product information. Write access is restricted to users with admin privileges."
    },
    "/customers/{customerId}": {
      "schema": {
        "$ref": "#/entities/Customer"
      },
      "description": "Stores customer data. Only the user who created it (ownerId) can read/write their own data."
    },
    "/sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/Sale"
      },
      "description": "Stores sale transaction data. The 'saleId' is the 'soNumber'. Only the user who created it (ownerId) can read/write it."
    },
    "/invoices/{invoiceId}": {
      "schema": {
        "$ref": "#/entities/Invoice"
      },
      "description": "Stores invoice documents. Only the user who created it (ownerId) can access it."
    },
    "/users/{uid}": {
      "description": "Stores user profile information, including their role."
    },
    "/salesOrders/{orderId}": {
      "description": "Stores individual items of a sales order. Only the user who created it can access it."
    },
    "/invoiceNumbers/{invoiceNumberId}": {
      "description": "Stores generated invoice numbers. Only the user who created it can access it."
    },
    "/spds/{spdId}": {
      "schema": {
        "$ref": "#/entities/SPD"
      },
      "description": "Stores SPD documents. The 'spdId' is the 'spd' field. Only the user who created it can access it."
    },
    "/taxInvoices/{taxInvoiceId}": {
      "schema": {
        "$ref": "#/entities/TaxInvoice"
      },
      "description": "Stores tax invoice documents. The 'taxInvoiceId' is the 'taxInvoiceNumber'. Only the user who created it can access it."
    }
  }
}
