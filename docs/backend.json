{
  "entities": {
    "User": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "addresses": { "type": "array" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "poNumber": { "type": "string" },
        "customer": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "SpdData": {
      "title": "SPD Dispatch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "courier": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles and roles"
    },
    "/customers/{id}": {
      "schema": "#/entities/Customer",
      "description": "Customer address book"
    },
    "/invoices/{id}": {
      "schema": "#/entities/Invoice",
      "description": "Billing documents"
    },
    "/spds/{id}": {
      "schema": "#/entities/SpdData",
      "description": "Document dispatch tracking"
    },
    "/sales/{id}": {
      "schema": "object",
      "description": "Purchase Orders registry"
    },
    "/products/{id}": {
      "schema": "object",
      "description": "Product inventory"
    }
  }
}