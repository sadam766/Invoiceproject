
{
  "entities": {
    "User": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "customerCode": { "type": "string", "description": "Unique ERP identity (e.g. ADH004)" },
        "email": { "type": "string" },
        "addresses": { "type": "array" },
        "billingSchedule": { "type": "string", "description": "Specific days/times for accepting invoices" },
        "virtualAccountNumber": { "type": "string", "description": "16-digit Mandiri VA" },
        "createdBy": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "erpInvoiceId": { "type": "string" },
        "soNumber": { "type": "string" },
        "poNumber": { "type": "string" },
        "customer": { "type": "string" },
        "customerCode": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "vaNumber": { "type": "string" },
        "vaStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "vaApprovedBy": { "type": "string" },
        "vaApprovedAt": { "type": "string" },
        "createdBy": { "type": "string", "description": "User ID of the creator" },
        "revisionLogs": { "type": "array" }
      }
    },
    "Notification": {
      "title": "In-App Notification",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "senderId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "invoiceId": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profiles and roles"
    },
    "/customers/{id}": {
      "schema": "#/entities/Customer",
      "description": "Customer address book"
    },
    "/invoices/{id}": {
      "schema": "#/entities/Invoice",
      "description": "Billing documents with item progress"
    },
    "/notifications/{id}": {
      "schema": "#/entities/Notification",
      "description": "System and approval notifications"
    }
  }
}
