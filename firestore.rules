
/**
 * @file Firestore Security Rules
 * @description Hierarki hak akses Dakota: Leader, Admin, dan Staff.
 *              Leader (fa@gmail.com) memiliki otoritas mutlak tanpa syarat lookup dokumen.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNGSI PEMBANTU ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Leader Check: Otoritas mutlak berdasarkan email permanen
    function isLeader() {
      return isSignedIn() && request.auth.token.email == 'fa@gmail.com';
    }

    // Admin Check: Leader ATAU user dengan role 'admin' di profilnya
    function isAdmin() {
      return isLeader() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Staff Check: Leader ATAU Admin ATAU user dengan status 'active'
    function isStaff() {
      return isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active');
    }

    // --- ATURAN KOLEKSI ---

    /**
     * Manajemen Profil User
     * Leader bisa mengelola semua user.
     * User biasa hanya bisa baca profil sendiri & buat profil saat register.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isLeader() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isLeader();
    }

    /**
     * Data Operasional (Products, Customers, Sales, SO, Invoices, VA)
     * Read: Leader, Admin, & Staff Aktif
     * Create/Update: Leader & Admin
     * Delete: Hanya Leader
     */
    match /products/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /customers/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }
    
    match /sales/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /salesOrders/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /invoices/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /invoiceNumbers/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /virtualAccounts/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    /**
     * Modul Pajak & SPD
     * Hanya Admin & Leader yang bisa akses (Read/Write).
     * Delete: Hanya Leader.
     */
    match /taxInvoices/{id} {
      allow read, list, create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /spds/{id} {
      allow read, list, create, update: if isAdmin();
      allow delete: if isLeader();
    }
  }
}
