rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email.toLowerCase() == 'fa@gmail.com'
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admin_roles/{userId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    // Koleksi Bisnis (Akses bersama untuk tim yang sudah login)
    // Termasuk: customers, products, sales, salesOrders, invoices, invoiceNumbers, spds, taxInvoices, virtualAccounts
    
    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /products/{id} { allow read, write: if isSignedIn(); }
    match /sales/{id} { allow read, write: if isSignedIn(); }
    match /salesOrders/{id} { allow read, write: if isSignedIn(); }
    match /invoices/{id} { allow read, write: if isSignedIn(); }
    match /invoiceNumbers/{id} { allow read, write: if isSignedIn(); }
    match /spds/{id} { allow read, write: if isSignedIn(); }
    match /taxInvoices/{id} { allow read, write: if isSignedIn(); }
    match /virtualAccounts/{id} { allow read, write: if isSignedIn(); }
  }
}