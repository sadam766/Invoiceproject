/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for customer and sale data,
 *              and restricts product creation/modification to admin users.
 *
 * Data Structure:
 * - /products/{productId}: Stores product information, write-protected for admins only.
 * - /customers/{customerId}: Stores customer data, accessible only by the customer themselves.
 * - /sales/{saleId}: Stores sale data, accessible only by the customer associated with the sale.
 * - /roles_admin/{uid}: Indicates admin privileges; presence of a document grants admin rights.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed for privacy.
 * - Admin privileges are determined by the existence of a document in `/roles_admin/{uid}`.
 * - Data schema is not strictly enforced, focusing on authorization.
 *
 * Denormalization for Authorization:
 * - The `sales` documents contain a denormalized `customerId` field to allow for authorization
 *   without needing to perform additional reads on the `customers` collection. This
 *   improves performance and simplifies the security rules.
 *
 * Structural Segregation:
 * - Data is segregated into top-level collections based on entity type (products, customers, sales).
 *   This simplifies access control patterns and enhances security.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows authenticated users to manage product information.
     * @path /products/{productId}
     * @allow (get, list): Any authenticated user can read product information.
     * @allow (create, update, delete): Any signed-in user can create, update, or delete products.
     * @principle Enforces role-based access control for product management.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows a customer to read and write their own customer data.
     * @path /customers/{customerId}
     * @allow (get, create, update, delete, list): Only the customer with matching UID can perform these operations.
     * @deny (get, create, update, delete, list): Other users cannot access this data.
     * @principle Enforces document ownership for customer data.
     */
    match /customers/{customerId} {
      allow get, list: if isOwner(customerId);
      allow create: if isOwner(customerId) && request.resource.data.id == customerId;
      allow update: if isOwner(customerId) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Allows a customer to read and write their own sale data, verified by customerId in the document.
     * @path /sales/{saleId}
     * @allow (get, create, update, delete, list): Only the customer associated with the sale can perform these operations.
     * @deny (get, create, update, delete, list): Other users cannot access this data.
     * @principle Enforces document ownership based on the `customerId` field in the sale document.
     */
    match /sales/{saleId} {
      allow get, list: if isCustomerForSale(resource.data.customerId);
      allow create: if isCustomerForSale(request.resource.data.customerId) && request.resource.data.customerId == request.auth.uid;
      allow update: if isCustomerForSale(resource.data.customerId) && resource != null && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isExistingCustomerForSale(resource.data.customerId);
    }

    /**
     * @description Determines admin privileges based on the existence of a document with the user's UID.
     * @path /roles_admin/{uid}
     * @allow (get, list): Publicly readable to determine admin status.
     * @allow (create): Only the user themselves can create this document (to self-nominate, requires additional backend logic to approve).
     * @deny (create, update, delete):  Updates and deletes are disallowed via rules.
     * @principle Grants admin privileges based on document existence.
     */
    match /roles_admin/{uid} {
      allow get, list: if true;
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCustomerForSale(customerId) {
      return isSignedIn() && request.auth.uid == customerId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isExistingCustomerForSale(customerId) {
        return isCustomerForSale(customerId) && resource != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  }
}
