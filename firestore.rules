
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for all user-generated data,
 *              and restricts product management to admin users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile and role information.
 * - /products/{productId}: Stores product information, readable by any user, writable only by admins.
 * - /customers/{customerId}: Accessible only by the owner.
 * - /sales/{saleId}: Accessible only by the owner.
 * - /salesOrders/{orderId}: Accessible only by the owner.
 * - /invoiceNumbers/{invoiceNumberId}: Accessible only by the owner.
 * - /invoices/{invoiceId}: Accessible only by the owner.
 * - /spds/{spdId}: Accessible only by the owner.
 * - /taxInvoices/{taxInvoiceId}: Accessible only by the owner.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getRole() == 'admin';
    }
    
    function isOwnerOfDoc() {
      return request.auth.uid == resource.data.ownerId;
    }
    
    function isCreatingOwnerDoc() {
       return request.auth.uid == request.resource.data.ownerId;
    }

    /**
     * @description Public user data and roles.
     * @path /users/{userId}
     * @allow (read): Any signed-in user can read public user profiles.
     * @allow (write): Users can only create/update their own profile.
     * @principle User profile management.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    /**
     * @description Products can be read by anyone, but only managed by admins.
     * @path /products/{productId}
     * @allow (read): Any authenticated user can read product information.
     * @allow (write): Only users with the 'admin' role can manage products.
     * @principle Enforces role-based access control for product management.
     */
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    /**
     * @description Enforces ownership for customer data.
     * @path /customers/{customerId}
     */
    match /customers/{customerId} {
      allow read, write: if isSignedIn() && isOwnerOfDoc();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
    }

    /**
     * @description Enforces ownership for sales order data.
     * @path /salesOrders/{orderId}
     */
    match /salesOrders/{orderId} {
       allow read, write: if isSignedIn() && isOwnerOfDoc();
       allow create: if isSignedIn() && isCreatingOwnerDoc();
    }

    /**
     * @description Enforces ownership for invoice number data.
     * @path /invoiceNumbers/{invoiceNumberId}
     */
    match /invoiceNumbers/{invoiceNumberId} {
        allow read, write: if isSignedIn() && isOwnerOfDoc();
        allow create: if isSignedIn() && isCreatingOwnerDoc();
    }

    /**
     * @description Enforces ownership for invoice data.
     * @path /invoices/{invoiceId}
     */
    match /invoices/{invoiceId} {
      allow read, write: if isSignedIn() && isOwnerOfDoc();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
    }
    
    /**
     * @description Enforces ownership for SPD data.
     * @path /spds/{spdId}
     */
    match /spds/{spdId} {
      allow read, write: if isSignedIn() && isOwnerOfDoc();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
    }
    
    /**
     * @description Enforces ownership for Tax Invoice data.
     * @path /taxInvoices/{taxInvoiceId}
     */
    match /taxInvoices/{taxInvoiceId} {
      allow read, write: if isSignedIn() && isOwnerOfDoc();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
    }

    /**
     * @description Enforces ownership for sales data.
     * @path /sales/{saleId}
     */
    match /sales/{saleId} {
      allow read, write: if isSignedIn() && isOwnerOfDoc();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
    }
  }
}
