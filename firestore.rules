/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model, primarily focused on securing sales data and customer information. It assumes an administrative role manages most data, with potential customer-specific sales data accessible to the customer.
 * @dataStructure
 *   - /customers/{customerId}: Stores customer profile data. Access is typically admin-controlled.
 *   - /products/{productId}: Stores product catalog data. Access can be public read or admin-controlled.
 *   - /customers/{customerId}/sales/{saleId}: Stores sales transactions associated with a specific customer. Can be configured to allow customer-specific access.
 *   - /sales_overviews/{salesOverviewId}: Stores aggregated sales data. Access is strictly admin-controlled.
 *   - /top_products/{topProductId}: Stores data on top-selling products. Access is admin-controlled.
 * @keySecurityDecisions
 *   - No public write access is granted to any collection.
 *   - The rules are written to be as restrictive as possible while allowing the application to function.
 *   - Data validation is minimal in this prototyping phase, focusing only on ownership and relationship integrity.
 *   - Read operations are generally more permissive than write operations, but still restricted where appropriate.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure customer data. Currently allows full read/write access. Intended for admin use.
     * @path /customers/{customerId}
     * @allow (get, list): if true - Allows any user to read customer data.
     * @allow (create, update, delete): if false - Requires proper validation and ownership checks for writes in production.
     * @deny (create, update, delete): if false - No write rules are defined yet. Add owner or role validation once the application is fully developed.
     * @principle Allows only read access to customer data for prototyping and requires validation and authorization checks for write operations.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner or role validation once the application is fully developed.
    }

    /**
     * @description Secure product catalog data. Currently allows public read-only access.
     * @path /products/{productId}
     * @allow (get, list): if true - Allows any user to read product data.
     * @allow (create, update, delete): if false - Requires proper validation and ownership checks for writes in production.
     * @deny (create, update, delete): if false - No write rules are defined yet. Add owner or role validation once the application is fully developed.
     * @principle Allows only read access to product data and requires validation and authorization checks for write operations.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add role-based validation for admin users.
    }

    /**
     * @description Secure sales data under a specific customer. Allows read access and restricts write access.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (get, list): if true - Allows any user to read sales data for a specific customer.
     * @allow (create): if request.resource.data.customerId == customerId; - Allows creating a sale if the customerId in the data matches the path.
     * @allow (update): if resource != null && request.resource.data.customerId == resource.data.customerId; - Allows updating a sale if the customerId in the data matches the existing customerId and the document exists.
     * @allow (delete): if false - No delete operations allowed
     * @deny (create): if request.resource.data.customerId != customerId; - Denies creating a sale if the customerId in the data does not match the path.
     * @deny (update): if resource == null || request.resource.data.customerId != resource.data.customerId; - Denies updating a sale if the customerId in the data does not match the existing customerId or the document does not exist.
     * @principle Enforces customer-specific sales data access and ensures data integrity for writes.
     */
    match /customers/{customerId}/sales/{saleId} {
        allow get, list: if true;
        allow create: if request.resource.data.customerId == customerId;
        allow update: if resource != null && request.resource.data.customerId == resource.data.customerId;
        allow delete: if false;
    }

    /**
     * @description Secure sales overview data. Access is strictly admin-controlled (no access granted in this prototype).
     * @path /sales_overviews/{salesOverviewId}
     * @allow (get, list, create, update, delete): if false - All operations are denied. Requires role-based validation for admin users in production.
     * @deny (get, list, create, update, delete): if true - No access allowed.
     * @principle Restricts access to sales overview data and requires validation and authorization checks for all operations.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get, list, create, update, delete: if false; // TODO: Add role-based validation for admin users.
    }

    /**
     * @description Secure top product data. Access is strictly admin-controlled (no access granted in this prototype).
     * @path /top_products/{topProductId}
     * @allow (get, list, create, update, delete): if false - All operations are denied. Requires role-based validation for admin users in production.
     * @deny (get, list, create, update, delete): if true - No access allowed.
     * @principle Restricts access to top product data and requires validation and authorization checks for all operations.
     */
    match /top_products/{topProductId} {
      allow get, list, create, update, delete: if false; // TODO: Add role-based validation for admin users.
    }
  }
}