rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // isSuperAdmin: Pengecekan langsung email leader utama
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'fa@gmail.com';
    }

    // isAdmin: Verifikasi otoritas berdasarkan dokumen user atau email super admin
    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Role-Based Access Control ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications: Dioptimalkan untuk provability kueri list (Ikon Lonceng)
    match /notifications/{id} {
      // Pengecekan read dipisah untuk memastikan kueri berfilter recipientId diizinkan secara statis
      allow read: if isSignedIn() && (
        request.auth.token.email == 'fa@gmail.com' || 
        request.auth.uid == resource.data.recipientId
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.token.email == 'fa@gmail.com' || 
        request.auth.uid == resource.data.recipientId
      );
      
      allow delete: if isAdmin();
    }

    // Core Business Collections
    match /invoiceNumbers/{id} {
      allow read, write: if isSignedIn();
    }

    match /invoices/{id} {
      allow read, write: if isSignedIn(); 
    }

    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /products/{id} { allow read, write: if isSignedIn(); }
    match /sales/{id} { allow read, write: if isSignedIn(); }
    match /salesOrders/{id} { allow read, write: if isSignedIn(); }
    match /spds/{id} { allow read, write: if isSignedIn(); }
    match /taxInvoices/{id} { allow read, write: if isSignedIn(); }
    match /virtualAccounts/{id} { allow read, write: if isSignedIn(); }
    
    // Support for collection group queries or nested paths
    match /{path=**}/invoices/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/notifications/{id} { 
      allow read: if isSignedIn() && (request.auth.token.email == 'fa@gmail.com' || request.auth.uid == resource.data.recipientId);
    }
  }
}