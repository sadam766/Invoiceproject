/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with admin privileges.
 *
 * Data Structure:
 * - /customers/{customerId}: Stores customer data; access is managed via admin roles.
 * - /products/{productId}: Stores product data; read access may be public, while writes are admin-restricted.
 * - /customers/{customerId}/sales/{saleId}: Stores sales data nested under customer documents; access is admin-controlled.
 * - /sales_overviews/{salesOverviewId}: Stores sales overview data; access is admin-controlled.
 * - /top_products/{topProductId}: Stores top product data; access is admin-controlled.
 *
 * Key Security Decisions:
 * - Admin-only write access for critical collections (sales overviews, top products).
 * - Read access is generally open unless there are write rules, so specific read constraints are not required.
 * - Assumes the existence of an `isAdmin()` function to check for admin privileges.
 *
 * Denormalization for Authorization:
 * - Sales documents under /customers/{customerId}/sales/{saleId} do not have denormalized authorization data, the rules assume that admin access is granted.
 *
 * Structural Segregation:
 * - Public product information is stored separately from private sales data to allow open read access where appropriate.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants admin access to manage customer data.
     * @path /customers/{customerId}
     * @allow (create, update, delete) if isAdmin()
     * @deny (create, update, delete) if !isAdmin()
     * @allow get, list: if true;
     * @principle Enforces admin-only write access for customer data.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Manages product data with potential public read access and admin-only writes.
     * @path /products/{productId}
     * @allow (create, update, delete) if isAdmin()
     * @deny (create, update, delete) if !isAdmin()
     * @allow get, list: if true;
     * @principle Allows public read access but restricts writes to admins.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Restricts access to sales data under a customer to admins.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (create, update, delete) if isAdmin()
     * @deny (create, update, delete) if !isAdmin()
     * @allow get, list: if isAdmin();
     * @principle Enforces admin-only access to sales data.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Grants admin access to manage sales overview data.
     * @path /sales_overviews/{salesOverviewId}
     * @allow (create, update, delete) if isAdmin()
     * @deny (create, update, delete) if !isAdmin()
     * @allow get, list: if isAdmin();
     * @principle Enforces admin-only access to sales overview data.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Restricts access to top product data to admins.
     * @path /top_products/{topProductId}
     * @allow (create, update, delete) if isAdmin()
     * @deny (create, update, delete) if !isAdmin()
     * @allow get, list: if isAdmin();
     * @principle Enforces admin-only access to top product data.
     */
    match /top_products/{topProductId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Helper function to determine if the user is an admin.
    function isAdmin() {
        return false; // TODO: Implement admin check, e.g., check for admin role in custom claims
    }
  }
}