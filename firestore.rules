/**
 * @file Firestore Security Rules for Sales Dashboard
 * @core_philosophy This ruleset prioritizes secure data access based on a combination of ownership and role-based access control.
 * It enforces a strict access model where applicable, particularly for user-specific data.
 * @data_structure The data is organized into top-level collections for `customers`, `products`, `sales_overviews`, and `top_products`.
 * Sales data is stored as a subcollection under individual customers.
 * @key_security_decisions Access to customer data is likely managed through admin roles or other means. Product data is globally accessible
 * or restricted to admin users. Sales overviews and top product data are likely admin controlled. Data is denormalized to avoid complex queries in rules.
 * @denormalization_for_authorization CustomerId is denormalized in Sale documents to enable efficient authorization rules without needing to fetch the Customer document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures customer documents, likely managed through admin roles.
     * @path /customers/{customerId}
     * @allow get, list: if false; // Access managed through other means.
     * @allow create: if false; // Access managed through other means.
     * @allow update: if false; // Access managed through other means.
     * @allow delete: if false; // Access managed through other means.
     * @principle Restricts access to customer data.
     */
    match /customers/{customerId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Secures product documents, globally accessible or restricted to admin users.
     * @path /products/{productId}
     * @allow get, list: if true; // Globally accessible product data.
     * @allow create: if false; // Access restricted to admin users.
     * @allow update: if false; // Access restricted to admin users.
     * @allow delete: if false; // Access restricted to admin users.
     * @principle Restricts write access to product data, allowing public read.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Secures sales documents under the corresponding customer.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow get, list: if isCustomer(customerId);
     * @allow create: if isCustomer(customerId) && request.resource.data.customerId == customerId;
     * @allow update: if isCustomer(customerId) && request.resource.data.customerId == customerId;
     * @allow delete: if isCustomer(customerId) && request.resource.data.customerId == customerId;
     * @principle Enforces customer-ownership for writes and validates relational integrity.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get, list: if isCustomer(customerId);
      allow create: if isCustomer(customerId) && request.resource.data.customerId == customerId;
      allow update: if isCustomer(customerId) && request.resource.data.customerId == customerId;
      allow delete: if isCustomer(customerId) && request.resource.data.customerId == customerId;
    }

    /**
     * @description Secures sales overview documents, likely admin controlled.
     * @path /sales_overviews/{salesOverviewId}
     * @allow get, list: if false; // Access restricted to admin users.
     * @allow create: if false; // Access restricted to admin users.
     * @allow update: if false; // Access restricted to admin users.
     * @allow delete: if false; // Access restricted to admin users.
     * @principle Restricts access to sales overview data.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Secures top product documents, likely admin controlled.
     * @path /top_products/{topProductId}
     * @allow get, list: if false; // Access restricted to admin users.
     * @allow create: if false; // Access restricted to admin users.
     * @allow update: if false; // Access restricted to admin users.
     * @allow delete: if false; // Access restricted to admin users.
     * @principle Restricts access to top product data.
     */
    match /top_products/{topProductId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCustomer(customerId) {
      return isSignedIn() && request.auth.uid == customerId;
    }
  }
}