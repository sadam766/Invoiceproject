rules_version = '2';
 service cloud.firestore {
  match /databases/{database}/documents {
 

  /**
   * @description Allows access to customer data. Access is likely managed through admin roles.
   * @path /customers/{customerId}
   * @allow (get, list) if false; // Example: Admin role check required, replace with actual admin check
   * @deny (create, update, delete) Always deny write access for non-admin users
   * @principle Restricts direct user access to customer data, requiring admin privileges for management
   */
  match /customers/{customerId} {
  allow get, list: if isSignedIn() && false;
  allow create, update, delete: if false;
  }
 

  /**
   * @description Allows read access to product information. Admin users can create, update, and delete product data.
   * @path /products/{productId}
   * @allow (get, list) if true; // Example: Products are publicly readable
   * @allow (create, update, delete) if false; // Example: Admin role check required, replace with actual admin check
   * @deny (create, update, delete) Always deny write access for non-admin users
   * @principle Restricts write access to product data to admin users, while allowing public read access
   */
  match /products/{productId} {
  allow get, list: if true;
  allow create, update, delete: if false;
  }
 

  /**
   * @description Restricts access to sales data under the corresponding customer.
   * The `customerId` is denormalized to enable filtering and efficient security rules.
   * @path /customers/{customerId}/sales/{saleId}
   * @allow (get, list) if false; // Example: Customer role check required, replace with actual customer check
   * @deny (create, update, delete) Always deny write access for non-admin users
   * @principle Restricts direct user access to sales data, requiring customer or admin privileges for management
   */
  match /customers/{customerId}/sales/{saleId} {
  allow get, list: if isSignedIn() && false;
  allow create, update, delete: if false;
  }
 

  /**
   * @description Allows access to sales overview data. Access will likely be admin controlled.
   * @path /sales_overviews/{salesOverviewId}
   * @allow (get, list) if false; // Example: Admin role check required, replace with actual admin check
   * @deny (create, update, delete) Always deny write access for non-admin users
   * @principle Restricts direct user access to sales overview data, requiring admin privileges for management
   */
  match /sales_overviews/{salesOverviewId} {
  allow get, list: if isSignedIn() && false;
  allow create, update, delete: if false;
  }
 

  /**
   * @description Allows access to top product data. Top products are stored globally, also likely admin controlled.
   * @path /top_products/{topProductId}
   * @allow (get, list) if false; // Example: Admin role check required, replace with actual admin check
   * @deny (create, update, delete) Always deny write access for non-admin users
   * @principle Restricts direct user access to top product data, requiring admin privileges for management
   */
  match /top_products/{topProductId} {
  allow get, list: if isSignedIn() && false;
  allow create, update, delete: if false;
  }
 

  function isSignedIn() {
  return request.auth != null;
  }
  }
 }