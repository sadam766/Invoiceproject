
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.toLowerCase() == 'fa@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow any signed-in user to read profile info for selection/audit logging
      allow read: if isSignedIn();
      // Registration is allowed for anyone signed in
      allow create: if isSignedIn();
      // Only owner or admin can update status/roles
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Shared Business Collections (Standard Access for Operations Team)
    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /products/{id} { allow read, write: if isSignedIn(); }
    match /sales/{id} { allow read, write: if isSignedIn(); }
    match /salesOrders/{id} { allow read, write: if isSignedIn(); }
    match /invoices/{id} { allow read, write: if isSignedIn(); }
    match /invoiceNumbers/{id} { allow read, write: if isSignedIn(); }
    match /spds/{id} { allow read, write: if isSignedIn(); }
    match /taxInvoices/{id} { allow read, write: if isSignedIn(); }
    match /virtualAccounts/{id} { allow read, write: if isSignedIn(); }
  }
}
