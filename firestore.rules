
/**
 * @file Firestore Security Rules
 * @description This ruleset allows any signed-in user to read all data to facilitate
 *              collaboration and prevent duplication. Write access is still
 *              controlled to ensure data integrity.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile and role information.
 * - /products/{productId}: Stores product information, readable by any user, writable only by admins.
 * - /customers, /sales, /salesOrders, etc.: All data is readable by any signed-in user.
 *   Writes are protected by ensuring the user is signed in and owns the document they are creating/modifying.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getRole() == 'admin';
    }
    
    function isOwnerOfDoc() {
      return request.auth.uid == resource.data.ownerId;
    }
    
    function isCreatingOwnerDoc() {
       return request.auth.uid == request.resource.data.ownerId;
    }

    /**
     * @description Public user data and roles.
     * @path /users/{userId}
     * @allow (read): Any signed-in user can read public user profiles.
     * @allow (write): Users can only create/update their own profile.
     * @principle User profile management.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    /**
     * @description Products can be read by anyone, but only managed by admins.
     * @path /products/{productId}
     * @allow (read): Any authenticated user can read product information.
     * @allow (write): Only users with the 'admin' role can manage products.
     * @principle Enforces role-based access control for product management.
     */
    match /products/{productId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    /**
     * @description Sales orders collection. Readable by all.
     */
    match /salesOrders/{orderId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && isCreatingOwnerDoc();
        allow update: if isSignedIn() && isCreatingOwnerDoc();
        allow delete: if isSignedIn() && isOwnerOfDoc();
    }

    /**
     * @description Shared data collections. Readable by all signed-in users.
     *              Write access is restricted to the owner of the document.
     */
    match /customers/{customerId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
      allow update, delete: if isSignedIn() && isOwnerOfDoc();
    }
    
    match /invoiceNumbers/{invoiceNumberId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
      allow update: if isSignedIn() && isCreatingOwnerDoc();
      allow delete: if isSignedIn() && isOwnerOfDoc();
    }
    
    match /invoices/{invoiceId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
      allow update: if isSignedIn() && isCreatingOwnerDoc();
      allow delete: if isSignedIn() && isOwnerOfDoc();
    }
    
    match /spds/{spdId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
      allow update, delete: if isSignedIn() && isOwnerOfDoc();
    }
    
    match /taxInvoices/{taxInvoiceId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
      allow update, delete: if isSignedIn() && isOwnerOfDoc();
    }
    
    match /sales/{saleId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingOwnerDoc();
      allow update, delete: if isSignedIn() && isOwnerOfDoc();
    }
  }
}
