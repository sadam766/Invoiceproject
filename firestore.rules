
/**
 * @file Firestore Security Rules
 * @description Implementasi hierarki hak akses Dakota: Leader, Admin, dan Staff.
 *              Leader (fa@gmail.com) memiliki otoritas penuh.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNGSI PEMBANTU ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Role Checks
    function isLeader() {
      return request.auth.token.email == 'fa@gmail.com' || getUserData().role == 'admin' && request.auth.token.email == 'fa@gmail.com';
    }

    function isAdmin() {
      return isLeader() || getUserData().role == 'admin';
    }
    
    function isStaff() {
      return isSignedIn() && getUserData().status == 'active';
    }

    // --- ATURAN KOLEKSI ---

    /**
     * Manajemen Profil User
     * Hanya Leader yang bisa mengelola semua user.
     * User biasa hanya bisa baca profil sendiri.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isLeader() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
    }

    /**
     * Data Operasional (Products, Customers, Sales, SO, Invoices, VA)
     * Create/Read/Update: Admin & Staff (Active)
     * Delete: Hanya Leader
     */
    match /products/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /customers/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }
    
    match /sales/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /salesOrders/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /invoices/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /invoiceNumbers/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /virtualAccounts/{id} {
      allow read, list: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    /**
     * Modul Pajak (Tax Invoices) & SPD
     * Hanya Admin & Leader yang bisa akses.
     */
    match /taxInvoices/{id} {
      allow read, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }

    match /spds/{id} {
      allow read, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isLeader();
    }
  }
}
