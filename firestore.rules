
/**
 * @file Firestore Security Rules
 * @description Aturan ini mengizinkan semua pengguna yang login untuk membaca dan menulis 
 *              semua data operasional guna memfasilitasi kolaborasi tim dan mencegah 
 *              terjadinya duplikasi data sesuai permintaan transparansi pengguna.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi pembantu untuk mengecek apakah user sudah login
    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi pembantu untuk mengecek kepemilikan (untuk profil user)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Profil Pengguna.
     * Hanya pemilik akun yang bisa mengubah data profilnya sendiri.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    /**
     * @description Koleksi Data Bersama (Kolaboratif).
     * Semua pengguna yang sudah login diizinkan untuk melihat, menambah, mengubah, 
     * dan menghapus data di koleksi berikut agar transparansi data terjaga.
     */
    
    match /products/{productId} {
      allow read, list, create, update, delete: if isSignedIn();
    }

    match /salesOrders/{orderId} {
      allow read, list, create, update, delete: if isSignedIn();
    }

    match /customers/{customerId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
    
    match /invoiceNumbers/{invoiceNumberId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
    
    match /invoices/{invoiceId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
    
    match /spds/{spdId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
    
    match /taxInvoices/{taxInvoiceId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
    
    match /sales/{saleId} {
      allow read, list, create, update, delete: if isSignedIn();
    }

    match /virtualAccounts/{vaId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
  }
}
