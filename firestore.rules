/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with separation of concerns.
 *
 * Data Structure:
 * - /customers/{customerId}: Stores customer data, likely admin-controlled.
 * - /products/{productId}: Stores product data, likely publicly readable or admin-controlled.
 * - /customers/{customerId}/sales/{saleId}: Stores sales data for each customer; customers do not have direct access to this collection.
 * - /sales_overviews/{salesOverviewId}: Stores aggregated sales data, likely admin-controlled.
 * - /top_products/{topProductId}: Stores data about top-selling products, likely admin-controlled.
 *
 * Key Security Decisions:
 * - List operation on `/invoices` is denied to all authenticated users.
 * - Customer and product data access are likely managed through admin roles.
 * - Sales data is associated with a customer and is not directly user-accessible.
 * - Aggregated sales overviews and top product data are likely admin-controlled.
 *
 * Denormalization for Authorization:
 * - Sales documents under `/customers/{customerId}/sales/{saleId}` denormalize the `customerId` to enable filtering and efficient security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Denies listing of `/invoices` for all users.
     * @path /invoices
     * @allow (get) - Not applicable (collection does not exist)
     * @deny (list) Any authenticated user attempts to list `/invoices` without explicit permission.
     * @principle Explicitly deny access to ensure a secure baseline.
     */
    match /invoices {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to customer data. Access is likely managed through other means (e.g. an admin role collection that is checked in security rules).
     * @path /customers/{customerId}
     * @allow (get) Public get access, contingent on future restriction.
     * @allow (create) An admin user creates a new customer profile.
     * @deny (update) A non-admin user attempts to modify a customer profile.
     * @deny (delete) A non-admin user attempts to delete a customer profile.
     * @principle Enforces admin-only access to customer data modifications.
     */
    match /customers/{customerId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to product data. Product data is globally accessible (read-only) or restricted to admin users.
     * @path /products/{productId}
     * @allow (get) Public get access to product information.
     * @deny (create) A non-admin user attempts to create a product.
     * @deny (update) A non-admin user attempts to modify product information.
     * @deny (delete) A non-admin user attempts to delete a product.
     * @principle Enforces read-only access to product data for non-admin users.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to sales data associated with a customer. The `customerId` is denormalized to enable filtering and efficient security rules.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (create) An admin user creates a new sale record for a customer.
     * @deny (get) A non-admin user attempts to read a sale record.
     * @deny (update) A non-admin user attempts to modify a sale record.
     * @deny (delete) A non-admin user attempts to delete a sale record.
     * @principle Enforces admin-only access to sales data.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to sales overview data. Access will likely be admin controlled.
     * @path /sales_overviews/{salesOverviewId}
     * @deny (get) A non-admin user attempts to read a sales overview record.
     * @deny (create) A non-admin user attempts to create a new sales overview.
     * @deny (update) A non-admin user attempts to modify a sales overview record.
     * @deny (delete) A non-admin user attempts to delete a sales overview record.
     * @principle Enforces admin-only access to sales overview data.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to top product data. Top products are stored globally, also likely admin controlled.
     * @path /top_products/{topProductId}
     * @deny (get) A non-admin user attempts to read a top product record.
     * @deny (create) A non-admin user attempts to create a new top product record.
     * @deny (update) A non-admin user attempts to modify a top product record.
     * @deny (delete) A non-admin user attempts to delete a top product record.
     * @principle Enforces admin-only access to top product data.
     */
    match /top_products/{topProductId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}