/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with admin privileges.
 *
 * Data Structure:
 * - /customers/{customerId}: Stores customer data; access is likely admin-controlled.
 * - /products/{productId}: Stores product data; access can be public read or admin-controlled.
 * - /customers/{customerId}/sales/{saleId}: Stores sales data nested under customers.
 * - /sales_overviews/{salesOverviewId}: Stores aggregated sales data; access is likely admin-controlled.
 * - /top_products/{topProductId}: Stores top product data; access is likely admin-controlled.
 *
 * Key Security Decisions:
 * - Anonymous authentication is allowed.
 * - Admin roles are not defined in this ruleset.
 * - Data shape validation is minimal during the prototyping phase.
 *
 * Denormalization for Authorization:
 * - The `customerId` is denormalized into the `/customers/{customerId}/sales/{saleId}` collection to enable efficient filtering and security rules without needing to fetch the customer document.
 *
 * Structural Segregation:
 * - Customer and Product data are stored in separate top-level collections, enabling efficient management and scalability.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to customer data based on admin privileges.
     * @path /customers/{customerId}
     * @allow (get, list) if false
     * @deny (create, update, delete) if false
     * @principle Restricts customer data access, likely admin-controlled.
     */
    match /customers/{customerId} {
      allow get, list: if false;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to product data or restricts it to admin users.
     * @path /products/{productId}
     * @allow get, list: if true
     * @deny (create, update, delete) if false
     * @principle Allows public read access to product data.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows access to sales data under the corresponding customer based on customer ownership.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow get, list: if false
     * @deny (create, update, delete) if false
     * @principle Enforces customer ownership for sales data under the customer.
     */
    match /customers/{customerId}/sales/{saleId} {
        allow get, list: if false;
        allow create, update, delete: if false;
    }

    /**
     * @description Allows access to sales overview data based on admin privileges.
     * @path /sales_overviews/{salesOverviewId}
     * @allow get, list: if false
     * @deny (create, update, delete) if false
     * @principle Restricts sales overview data access, likely admin-controlled.
     */
    match /sales_overviews/{salesOverviewId} {
        allow get, list: if false;
        allow create, update, delete: if false;
    }

    /**
     * @description Allows access to top product data based on admin privileges.
     * @path /top_products/{topProductId}
     * @allow get, list: if false
     * @deny (create, update, delete) if false
     * @principle Restricts top product data access, likely admin-controlled.
     */
    match /top_products/{topProductId} {
        allow get, list: if false;
        allow create, update, delete: if false;
    }
  }
}