/**
 * @fileoverview Firestore Security Rules for Sales Dashboard App
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for sales data, allowing users to manage their own sales records. Other data, such as customers, products, sales overviews, and top products, is publicly readable.
 *
 * Data Structure:
 * - /customers/{customerId}: Stores customer profiles.
 * - /customers/{customerId}/sales/{saleId}: Stores sales transactions for each customer.
 * - /products/{productId}: Stores product information.
 * - /salesOverview/{salesOverviewId}: Stores global sales overview data.
 * - /topProducts/{topProductId}: Stores global top product data.
 *
 * Key Security Decisions:
 * - Customers can only create, update, or delete their own sales records (path-based ownership).
 * - Customer profiles, product data, sales overview data, and top product data are publicly readable.
 * - Listing sales subcollection is only allowed by the owner.
 *
 * Denormalization for Authorization:
 *  - Sales are stored as subcollections under the customer to simplify ownership checks using path-based rules. The `customerId` is implicit in the path `/customers/{customerId}/sales/{saleId}`, so we don't need to duplicate it in the Sale document itself. This avoids costly `get()` calls to check ownership.
 *
 * Structural Segregation:
 * - Private sales data is stored under the `/customers/{customerId}/sales/{saleId}` path, while public product and overview data reside in top-level collections. This separation ensures that public data can be listed without exposing private sales information.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the request is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user IDs match, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing document.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user IDs match and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && resource.data != null;
    }

    /**
     * @description Defines rules for the /customers/{customerId} collection.
     * @path /customers/{customerId}
     * @allow (create) User with ID 'user123' can create a customer document with ID 'user123'.
     * @deny (create) User with ID 'user456' cannot create a customer document with ID 'user123'.
     * @allow (get, list) Any user can read customer profiles.
     * @deny (update, delete) Only the user with a matching customer ID can update or delete their profile.
     * @principle Enforces document ownership for writes, allows public reads.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isOwner(customerId);
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Defines rules for the /customers/{customerId}/sales/{saleId} collection.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (create) User with ID 'user123' can create a sale document under customer 'user123'.
     * @deny (create) User with ID 'user456' cannot create a sale document under customer 'user123'.
     * @allow (get, list) User with ID 'user123' can read or list sales documents under customer 'user123'.
     * @deny (update, delete) Only the user with a matching customer ID can update or delete sales records.
     * @principle Enforces document ownership for writes, restricts listing to the owner.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get: if isOwner(customerId);
      allow list: if isOwner(customerId);
      allow create: if isOwner(customerId);
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Defines rules for the /products/{productId} collection.
     * @path /products/{productId}
     * @allow (get, list) Any user can read product information.
     * @deny (create, update, delete) No user can create, update, or delete product information.
     * @principle Allows public reads, restricts writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Defines rules for the /salesOverview/{salesOverviewId} collection.
     * @path /salesOverview/{salesOverviewId}
     * @allow (get, list) Any user can read sales overview data.
     * @deny (create, update, delete) No user can create, update, or delete sales overview data.
     * @principle Allows public reads, restricts writes.
     */
    match /salesOverview/{salesOverviewId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Defines rules for the /topProducts/{topProductId} collection.
     * @path /topProducts/{topProductId}
     * @allow (get, list) Any user can read top product data.
     * @deny (create, update, delete) No user can create, update, or delete top product data.
     * @principle Allows public reads, restricts writes.
     */
    match /topProducts/{topProductId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}