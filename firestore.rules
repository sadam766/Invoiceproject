rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner (user).
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the request is made by an existing owner (user), verifying the document exists.
     */
    function isExistingOwner(userId) {
      return isOwner(resource.data.userId);
    }

    /**
     * @description Rules for the /customers/{customerId} collection.
     * @path /customers/{customerId}
     * @allow (create) - Authenticated user can create a customer document if the customerId matches their UID.
     * @allow (get, list, update, delete) - Authenticated user can only access their own customer document.
     * @deny (create) - An unauthenticated user cannot create a customer document.
     * @deny (update) - A different authenticated user cannot update this customer document.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /customers/{customerId} {
      // Read rules
      allow get: if isOwner(customerId);
      allow list: if isOwner(customerId);

      // Write rules
      allow create: if isSignedIn() && isOwner(customerId);
      allow update: if isSignedIn() && isOwner(customerId);
      allow delete: if isSignedIn() && isOwner(customerId);
    }

    /**
     * @description Rules for the /customers/{customerId}/sales/{saleId} collection.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (create) - Authenticated user can create a sale document under their customer ID.
     * @allow (get, list, update, delete) - Authenticated user can only access sales documents under their customer ID.
     * @deny (create) - An unauthenticated user cannot create a sale document.
     * @deny (update) - A different authenticated user cannot update this sale document.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /customers/{customerId}/sales/{saleId} {
      // Read rules
      allow get: if isOwner(customerId);
      allow list: if isOwner(customerId);

      // Write rules
      allow create: if isSignedIn() && isOwner(customerId);
      allow update: if isSignedIn() && isOwner(customerId);
      allow delete: if isSignedIn() && isOwner(customerId);
    }

    /**
     * @description Rules for the /products/{productId} collection.
     * @path /products/{productId}
     * @allow (get, list) - Any user can read product information.
     * @deny (create, update, delete) - No one can modify product information through the client.
     * @principle Public read access with no write access.
     */
    match /products/{productId} {
      // Read rules
      allow get, list: if true;

      // Write rules
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the /salesOverview/{salesOverviewId} collection.
     * @path /salesOverview/{salesOverviewId}
     * @allow (get, list) - Any user can read sales overview information.
     * @deny (create, update, delete) - No one can modify sales overview information through the client.
     * @principle Public read access with no write access.
     */
    match /salesOverview/{salesOverviewId} {
      // Read rules
      allow get, list: if true;

      // Write rules
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the /topProducts/{topProductId} collection.
     * @path /topProducts/{topProductId}
     * @allow (get, list) - Any user can read top product information.
     * @deny (create, update, delete) - No one can modify top product information through the client.
     * @principle Public read access with no write access.
     */
    match /topProducts/{topProductId} {
      // Read rules
      allow get, list: if true;

      // Write rules
      allow create, update, delete: if false;
    }
    
    /**
     * @description Rules for the /invoiceNumbers/{invoiceNumberId} collection.
     * @path /invoiceNumbers/{invoiceNumberId}
     * @allow (get, list) - Any user can read invoice number information.
     * @deny (create, update, delete) - No one can modify invoice number information through the client.
     * @principle Public read access with no write access.
     */
    match /invoiceNumbers/{invoiceNumberId} {
      // Read rules
      allow get, list: if true;

      // Write rules
      allow create, update, delete: if false;
    }
  }
}