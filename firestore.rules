
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'fa@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Notifications: Simplified for List Sync ---
    match /notifications/{docId} {
      allow read, list: if isSignedIn() && (
        request.auth.uid == resource.data.recipientId || 
        request.auth.token.email == "fa@gmail.com"
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.recipientId || 
        request.auth.token.email == "fa@gmail.com"
      );
      
      allow delete: if isAdmin();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Core Business Collections ---
    match /invoiceNumbers/{id} { allow read, write: if isSignedIn(); }
    match /invoices/{id} { allow read, write: if isSignedIn(); }
    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /products/{id} { allow read, write: if isSignedIn(); }
    match /sales/{id} { allow read, write: if isSignedIn(); }
    match /salesOrders/{id} { allow read, write: if isSignedIn(); }
    match /spds/{id} { allow read, write: if isSignedIn(); }
    match /taxInvoices/{id} { allow read, write: if isSignedIn(); }
    match /virtualAccounts/{id} { allow read, write: if isSignedIn(); }
    
    // Global fallback
    match /{path=**}/invoices/{id} { allow read, write: if isSignedIn(); }
  }
}
