/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with separation of concerns.
 *
 * Data Structure:
 * - /customers/{customerId}: Stores customer data, likely with admin-controlled access.
 * - /products/{productId}: Stores product information, either publicly accessible or admin-controlled.
 * - /customers/{customerId}/sales/{saleId}: Stores sales data associated with a specific customer, enabling customer-specific data access.
 * - /sales_overviews/{salesOverviewId}: Stores aggregated sales overview data, accessible by admins only.
 * - /top_products/{topProductId}: Stores data about top-selling products, accessible by admins only.
 *
 * Key Security Decisions:
 * - Public listing of sales data is disallowed; access to sales is restricted to the associated customer or admin roles.
 * - Most data access is restricted to logged-in users.
 * - The rules do not enforce schema validation during this prototyping phase but will enforce referential integrity where appropriate.
 *
 * Denormalization for Authorization:
 * - The sales documents under `/customers/{customerId}/sales/{saleId}` are intended to contain a `customerId` field, enabling direct access control based on customer ownership without requiring additional `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows admins to manage customer data. Access to individual customer documents can be further restricted based on roles.
     * @path /customers/{customerId}
     * @allow get: if isSignedIn(); // In a real-world situation this would be role-based.
     * @allow list: if false; // Listing of customers is not allowed.
     * @allow create: if false; // Only admins can create customers.
     * @allow update: if false; // Only admins can update customer data.
     * @allow delete: if false; // Only admins can delete customers.
     * @principle Restricts customer data access to admins.
     */
    match /customers/{customerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn(); // In a real-world situation this would be role-based.
      allow list: if false; // Listing of customers is not allowed.
      allow create: if false; // Only admins can create customers.
      allow update: if false; // Only admins can update customer data.
      allow delete: if false; // Only admins can delete customers.
    }

    /**
     * @description Allows public read access to product information or restricts it to admins.
     * @path /products/{productId}
     * @allow get: if true;
     * @allow list: if true;
     * @allow create: if false; // Only admins can create products.
     * @allow update: if false; // Only admins can update product data.
     * @allow delete: if false; // Only admins can delete products.
     * @principle Restricts write access to product data to admins, allows public read.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // Only admins can create products.
      allow update: if false; // Only admins can update product data.
      allow delete: if false; // Only admins can delete products.
    }

    /**
     * @description Allows access to sales data only to the customer to which the sale belongs or to an admin.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow get: if isCustomer(customerId);
     * @allow list: if isCustomer(customerId);
     * @allow create: if isCustomer(customerId) && request.resource.data.customerId == customerId;
     * @allow update: if isExistingCustomer(customerId) && request.resource.data.customerId == customerId;
     * @allow delete: if isExistingCustomer(customerId) && request.resource.data.customerId == customerId;
     * @principle Enforces customer-based ownership for sales data.
     */
    match /customers/{customerId}/sales/{saleId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isCustomer(customerId) {
        return isSignedIn() && request.auth.uid == customerId;
      }

      function isExistingCustomer(customerId) {
        return isCustomer(customerId) && resource != null;
      }

      allow get: if isCustomer(customerId);
      allow list: if isCustomer(customerId);
      allow create: if isCustomer(customerId) && request.resource.data.customerId == customerId;
      allow update: if isExistingCustomer(customerId) && request.resource.data.customerId == customerId;
      allow delete: if isExistingCustomer(customerId) && request.resource.data.customerId == customerId;
    }

    /**
     * @description Restricts access to sales overview data to admins only.
     * @path /sales_overviews/{salesOverviewId}
     * @allow get: if false; // Only admins can view sales overviews.
     * @allow list: if false; // Listing sales overviews is not allowed.
     * @allow create: if false; // Only admins can create sales overviews.
     * @allow update: if false; // Only admins can update sales overviews.
     * @allow delete: if false; // Only admins can delete sales overviews.
     * @principle Restricts sales overview data access to admins.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get: if false; // Only admins can view sales overviews.
      allow list: if false; // Listing sales overviews is not allowed.
      allow create: if false; // Only admins can create sales overviews.
      allow update: if false; // Only admins can update sales overviews.
      allow delete: if false; // Only admins can delete sales overviews.
    }

    /**
     * @description Restricts access to top product data to admins only.
     * @path /top_products/{topProductId}
     * @allow get: if false; // Only admins can view top products.
     * @allow list: if false; // Listing top products is not allowed.
     * @allow create: if false; // Only admins can create top products.
     * @allow update: if false; // Only admins can update top product data.
     * @allow delete: if false; // Only admins can delete top products.
     * @principle Restricts top product data access to admins.
     */
    match /top_products/{topProductId} {
      allow get: if false; // Only admins can view top products.
      allow list: if false; // Listing top products is not allowed.
      allow create: if false; // Only admins can create top products.
      allow update: if false; // Only admins can update top product data.
      allow delete: if false; // Only admins can delete top products.
    }

    /**
     * @description Denies listing of the `invoices` collection. No additional information on why `invoices` was not declared, the instruction is to deny list operations
     * @path /invoices
     * @allow get: if false;
     * @allow list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Denies listing of the invoices collection.
     */
    match /invoices {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }
}