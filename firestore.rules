/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with public read access to certain collections.
 *
 * Data Structure:
 * - /customers/{customerId}: Customer data; likely admin-controlled.
 * - /products/{productId}: Product data; publicly readable or admin-controlled.
 * - /customers/{customerId}/sales/{saleId}: Sales data nested under customers, enables listing sales per customer.
 * - /sales_overviews/{salesOverviewId}: Sales overview data; admin-controlled.
 * - /top_products/{topProductId}: Top product data; admin-controlled.
 *
 * Key Security Decisions:
 * - Public read access is granted to the /products collection, assuming it contains non-sensitive data.
 * - All write operations are restricted and must be explicitly allowed based on admin roles or other criteria.
 * - The rules prioritize authorization independence by avoiding hierarchical `get()` calls.
 *
 * Denormalization for Authorization:
 * - Sales documents under `/customers/{customerId}/sales/{saleId}` should contain the customerId.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to customer data. Access is likely managed through an admin role.
     * @path /customers/{customerId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts all access to customer data, assuming admin-level control.
     */
    match /customers/{customerId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to product data. Publicly readable or restricted to admin users.
     * @path /products/{productId}
     * @allow get, list: if true;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Grants public read access to product information; restricts all write operations.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to sales data nested under a specific customer.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts all access to sales data under customers.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to sales overview data. Likely admin controlled.
     * @path /sales_overviews/{salesOverviewId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts all access to sales overview data.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to top product data. Likely admin controlled.
     * @path /top_products/{topProductId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts all access to top product data.
     */
    match /top_products/{topProductId} {
      allow get, list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    /**
     * @description Controls access to invoice number data.  Access is denied as a safe default in this prototype.
     * @path /invoiceNumbers/{invoiceNumberId}
     * @allow get: if false;
     * @allow list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Restricts all access to invoice number data.
     */
    match /invoiceNumbers/{invoiceNumberId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}