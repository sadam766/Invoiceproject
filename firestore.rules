/**
 * @fileoverview Firestore Security Rules for the Sales Dashboard application.
 *
 * Core Philosophy:
 * This ruleset prioritizes authorization independence and aims to provide secure,
 * yet permissive, access to data for prototyping. It enforces ownership for
 * customer-specific data and allows public read access to global sales data.
 *
 * Data Structure:
 * - /customers/{customerId}: Stores customer profiles.
 * - /customers/{customerId}/sales/{saleId}: Stores sales records for each customer.
 * - /products/{productId}: Stores product details.
 * - /salesOverview/{salesOverviewId}: Stores global sales overview data.
 * - /topProducts/{topProductId}: Stores information about top-selling products.
 *
 * Key Security Decisions:
 * - Customers can only access their own data (customer profiles and sales records).
 * - Global sales data (sales overview, top products) is publicly readable.
 * - Schema validation is relaxed to enable rapid prototyping. Only the consistency
 *   of owner IDs is enforced.
 * - Listing all customers, products, sales overviews or top products is disallowed to prevent data leakage, since these are global data stores.
 *
 * Denormalization for Authorization:
 * - Path-based ownership is used for sales records, ensuring that each sale is
 *   associated with a customer. This simplifies the security rules and avoids
 *   the need for complex `get()` calls.
 *
 * Structural Segregation:
 * - Public data (sales overview, top products) is stored in separate, top-level
 *   collections to allow for public read access without compromising the security
 *   of private customer data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the requesting user is signed in.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Verifies user authentication.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the requesting user is the owner of the resource.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Enforces resource ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the requesting user is the existing owner of the resource.
     * @path N/A (Helper function)
     * @allow N/A (Helper function)
     * @deny N/A (Helper function)
     * @principle Enforces resource ownership and existence.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && exists(resource.data);
    }

    /**
     * @description Rules for customer profiles.
     * @path /customers/{customerId}
     * @allow (create) If the user's UID matches the customerId.
     * @allow (get, update, delete) If the user is the owner of the customer profile.
     * @deny (create) If the user's UID does not match the customerId.
     * @deny (get, update, delete) If the user is not the owner of the customer profile.
     * @principle Enforces document ownership for customer profiles.
     */
    match /customers/{customerId} {
      allow get: if isOwner(customerId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(customerId);
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Rules for sales records associated with a customer.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (create) If the user is the owner of the customer profile and the sale's customerId matches the path.
     * @allow (get, update, delete) If the user is the owner of the customer profile and the sale exists.
     * @deny (create) If the user is not the owner of the customer profile or the sale's customerId does not match the path.
     * @deny (get, update, delete) If the user is not the owner of the customer profile.
     * @principle Enforces document ownership for sales records, ensuring sales are only accessible by their associated customer.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get: if isOwner(customerId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(customerId);
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Rules for product information.
     * @path /products/{productId}
     * @allow (get, list) Public read access to product information.
     * @deny (create, update, delete) No write access to product information.
     * @principle Provides public read access to product data while restricting write access.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for sales overview data.
     * @path /salesOverview/{salesOverviewId}
     * @allow (get, list) Public read access to sales overview data.
     * @deny (create, update, delete) No write access to sales overview data.
     * @principle Provides public read access to sales overview data while restricting write access.
     */
    match /salesOverview/{salesOverviewId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for top-selling product information.
     * @path /topProducts/{topProductId}
     * @allow (get, list) Public read access to top products data.
     * @deny (create, update, delete) No write access to top products data.
     * @principle Provides public read access to top products data while restricting write access.
     */
    match /topProducts/{topProductId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}