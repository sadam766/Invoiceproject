rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // isAdmin: Memverifikasi otoritas leader atau administrator
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'fa@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'staff') == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Role-Based Access Control ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications: Diperlukan untuk alur Approval VA & Alert Lonceng
    match /notifications/{id} {
      // Allow read if user is the recipient OR is an admin
      // Split into get and list for better query matching
      allow get, list: if isSignedIn() && (
        request.auth.token.email == 'fa@gmail.com' ||
        isAdmin() || 
        request.auth.uid == resource.data.recipientId
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.token.email == 'fa@gmail.com' ||
        isAdmin() || 
        request.auth.uid == resource.data.recipientId
      );
      allow delete: if isAdmin();
    }

    // Core Business Collections
    match /invoiceNumbers/{id} {
      allow read, write: if isSignedIn();
    }

    match /invoices/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /products/{id} { allow read, write: if isSignedIn(); }
    
    // Sales: Akses Hapus diberikan prioritas tinggi untuk Leader Utama
    match /sales/{id} { 
      allow read, create, update: if isSignedIn(); 
      allow delete: if isAdmin(); 
    }
    
    match /salesOrders/{id} { allow read, write: if isSignedIn(); }
    match /spds/{id} { allow read, write: if isSignedIn(); }
    match /taxInvoices/{id} { allow read, write: if isSignedIn(); }
    match /virtualAccounts/{id} { allow read, write: if isSignedIn(); }
  }
}