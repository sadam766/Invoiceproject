rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows administrators to manage customer data.
     * @path /customers/{customerId}
     * @allow (create, update, delete) if isAdmin() with valid data
     * @allow (get, list) if isAdmin()
     * @deny (create, update, delete) if not isAdmin()
     * @principle Restricts customer data management to administrators.
     */
    match /customers/{customerId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Allows administrators to manage product data.  Potentially allows public read access.
     * @path /products/{productId}
     * @allow (get, list) if true (for public read access, otherwise restricted to admins)
     * @allow (create, update, delete) if isAdmin() with valid data
     * @deny (create, update, delete) if not isAdmin()
     * @principle Restricts product data management to administrators.  Potentially allows public read access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Allows administrators to manage sales data for a specific customer.
     * @path /customers/{customerId}/sales/{saleId}
     * @allow (create, update, delete) if isAdmin() with valid data
     * @allow (get, list) if isAdmin()
     * @deny (create, update, delete) if not isAdmin()
     * @principle Restricts sales data management to administrators.
     */
    match /customers/{customerId}/sales/{saleId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Allows administrators to manage sales overview data.
     * @path /sales_overviews/{salesOverviewId}
     * @allow (create, update, delete) if isAdmin() with valid data
     * @allow (get, list) if isAdmin()
     * @deny (create, update, delete) if not isAdmin()
     * @principle Restricts sales overview data management to administrators.
     */
    match /sales_overviews/{salesOverviewId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Allows administrators to manage top product data.
     * @path /top_products/{topProductId}
     * @allow (create, update, delete) if isAdmin() with valid data
     * @allow (get, list) if isAdmin()
     * @deny (create, update, delete) if not isAdmin()
     * @principle Restricts top product data management to administrators.
     */
    match /top_products/{topProductId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }


    /**
     * @description Allows access to invoice numbers.
     * @path /invoiceNumbers/{invoiceNumberId}
     * @allow get if isAdmin()
     * @allow list if isAdmin()
     * @allow create if false
     * @allow update if false
     * @allow delete if false
     * @principle Restricts access to invoice numbers to administrators only.
     */
    match /invoiceNumbers/{invoiceNumberId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }

  // Helper function to check if the user is an admin.
  function isAdmin() {
    // Replace this with your actual admin check logic.
    // For example, check if the user's UID exists as a document in a `/roles_admin/{uid}` collection.
    return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
  }

  // Helper function to check if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to check if the user is the owner of the resource.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }
}