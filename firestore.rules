/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for customer and sale data,
 *              and restricts product management to admin users. It also secures sales orders
 *              and invoice numbers under user ownership.
 *
 * Data Structure:
 * - /products/{productId}: Stores product information, readable by any user, writable only by admins.
 * - /customers/{customerId}: Stores customer data, accessible only by the customer who created it.
 * - /sales/{saleId}: Stores sale data, accessible only by the customer associated with the sale.
 * - /salesOrders/{orderId}: Stores sales order items, accessible only by the user who created them.
 * - /invoiceNumbers/{invoiceNumberId}: Stores invoice numbers, accessible only by the user who created them.
 * - /users/{uid}: Stores user profile and role information.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getRole() == 'admin';
    }

    /**
     * @description Public user data and roles.
     * @path /users/{userId}
     * @allow (read): Any signed-in user can read public user profiles.
     * @allow (write): Users can only create/update their own profile.
     * @principle User profile management.
     */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    /**
     * @description Products can be read by anyone, but only managed by admins.
     * @path /products/{productId}
     * @allow (read): Any authenticated user can read product information.
     * @allow (write): Only users with the 'admin' role can manage products.
     * @principle Enforces role-based access control for product management.
     */
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    /**
     * @description Enforces ownership for customer data.
     * @path /customers/{customerId}
     * @allow (read, write): Only the user who created the customer document can access it.
     *                       The query from the client MUST include `where('ownerId', '==', request.auth.uid)`.
     * @principle Enforces strict data ownership.
     */
    match /customers/{customerId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    /**
     * @description Enforces ownership for sales order data.
     * @path /salesOrders/{orderId}
     * @allow (read, write): Only the user who created the sales order can access it.
     *                       The query from the client MUST include `where('ownerId', '==', request.auth.uid)`.
     * @principle Enforces strict data ownership.
     */
    match /salesOrders/{orderId} {
       allow read, write: if isSignedIn() && request.auth.uid == resource.data.ownerId;
       allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    /**
     * @description Enforces ownership for invoice number data.
     * @path /invoiceNumbers/{invoiceNumberId}
     * @allow (read, write): Only the user who created the invoice number can access it.
     *                       The query from the client MUST include `where('ownerId', '==', request.auth.uid)`.
     * @principle Enforces strict data ownership.
     */
    match /invoiceNumbers/{invoiceNumberId} {
        allow read, write: if isSignedIn() && request.auth.uid == resource.data.ownerId;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    /**
     * @description Enforces ownership for sales data.
     * @path /sales/{saleId}
     * @allow (read, write): Only the user who created the sale document can access it.
     *                       The query from the client MUST include `where('ownerId', '==', request.auth.uid)`.
     * @principle Enforces strict data ownership based on an `ownerId` field.
     */
    match /sales/{saleId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
